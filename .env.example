# ── WhatsApp / Meta ───────────────────────
# Token you choose yourself — paste the same value into Meta's webhook dashboard
WEBHOOK_VERIFY_TOKEN=your_random_secret_token_here

# Permanent access token from Meta Developer Dashboard → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token_here

# Phone Number ID from Meta Developer Dashboard → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ── Google Sheets ─────────────────────────
# The long ID from your sheet's URL:
# https://docs.google.com/spreadsheets/d/  THIS_PART  /edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Paste the entire service account JSON as a single line (escape quotes if needed)
# Download this from Google Cloud Console → IAM → Service Accounts → Keys → JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── PDF Document ──────────────────────────
# Public URL to the PDF file to send when user clicks "Yes"
# (Google Drive direct link, Cloudinary, S3, etc.)
PDF_URL=https://example.com/your-program-details.pdf
PDF_FILENAME=Program_Details.pdf
PDF_CAPTION=Here are the program details.

# ── Server ────────────────────────────────
PORT=3000
